// Reservadas y tipos
int x = 495;
float y = 100.001;
char c = '¿';
boolean b = true;

void main() {
    // Enteros: bin, oct, hex (A-F mayúsculas), decimal
    int b1 = 0b111101111;
    int o1 = 0757;
    int h1 = 0x1EF;

    // Reales: punto y científica
    float f1 = 9.87e-2;
    float f2 = 5e5;

    // Operaciones aritméticas y booleanas
    x = x + 10;
    x = x - 5;
    x = x * 2;
    x = x / 3;

    b = (x >= 10) && (x <= 100) || !false;
    b = (y > 10.3) && (y < 200e-1) || (x == 495);

    // Control básico
    if (b) { print(c); } else { print('a'); }

    do { x = x + 1; } while (x < 5);

    return;
}

/* comentario
   multilinea con símbolos: + - * / && || == <= >= { } ( ) ; , .
*/
print(x);
